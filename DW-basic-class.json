      "alinhamento": [
        { "id": 21, "nome": "Bom", "descricao": "Executar sua arte para ajudar alguém.", "exclusivo": true },
        { "id": 22, "nome": "Neutro", "descricao": "Evitar um conflito ou desfaça uma situação tensa.", "exclusivo": true },
