      "movimentos_raciais": [
        { "classe": "Bárbaro", "tipo": "Racial", "nome": "Forasteiro", "descricao": "Você pode ser um elfo, anão, halfling ou humano, mas seu povo não é dessas redondezas. No início de cada sessão, o MJ lhe perguntará algo a respeito de sua terra natal, por que você foi embora ou o que deixou para trás. Se responder, marque XP." }
      ],
      "movimentos_iniciais": [
        { "classe": "Bárbaro", "tipo": "Inicial", "nome": "Apetite hercúleo", "descricao": "Outras pessoas podem se contentar apenas com o gosto do vinho, o domínio sobre um servo ou ambos, mas você quer mais. Escolha dois apetites. Enquanto estiver perseguindo um de seus apetites, se realizar algum movimento, no lugar de rolar 2d6 você rola 1d6+1d8. Se o d6 apresentar o maior resultado do par, o MJ também irá introduzir uma complicação ou perigo que surge a partir de sua busca implacável.\n•\tPura destruição\n•\tPoder sobre outras pessoas\n•\tPrazeres mortais\n•\tConquista\n•\tRiquezas e propriedades\n•\tFama e glória" },
        { "classe": "Bárbaro", "tipo": "Inicial", "nome": "Controle da situação", "descricao": "Você recebe +1 constante para seu último suspiro. Quando realizar o último suspiro, com <span class='badge'>7-9</span> você pode fazer uma oferta para a Morte em troca de sua vida. Se a Morte aceitar, você viverá de novo. Caso contrário, você morre." },
        { "classe": "Bárbaro", "tipo": "Inicial", "nome": "Musculoso", "descricao": "Quando portar uma arma, ela recebe os rótulos poderoso e grotesco." },
        { "classe": "Bárbaro", "tipo": "Inicial", "nome": "O que você está esperando?", "descricao": "Quando gritar um desafio para seus inimigos, role+CON. Com <span class='badge'>10+</span> eles passam a lhe tratar como a ameaça mais óbvia a ser enfrentada, ignorando os seus companheiros, e você recebe +2 de dano constante contra eles. Com <span class='badge'>7-9</span> ou tolos dentre eles) caem em suas provocações." },
        { "classe": "Bárbaro", "tipo": "Inicial", "nome": "Armadura de Placas e portando aço", "descricao": "Você ignora o rótulo desengonçada das armaduras que vestir.", "exclusivo": true },
        { "classe": "Bárbaro", "tipo": "Inicial", "nome": "Desinpedido e ileso", "descricao": "Enquanto estiver abaixo de sua Carga, e não estiver usando armadura nem escudo, receba +1 de armadura.", "exclusivo": true }
      ],
      "movimentos_avancados_2_5": [
        { "classe": "Bárbaro", "id": 10, "nome": "Continuo faminto", "descricao": "Escolha um apetite adicional." },
        { "classe": "Bárbaro", "id": 11, "nome": "Apetite por destruição", "descricao": "Pegue um movimento da lista do guerreiro, bardo ou ladrão. Você não pode pegar os movimentos de multiclasse dessas classes." },
        { "classe": "Bárbaro", "id": 12, "nome": "Meu amor por você é como um caminhão", "descricao": "Quando realizar um feito de força, nomeie alguém presente que tenha ficado impressionado por ele, e receba +1 adiante para negociar com essa pessoa." },
        { "classe": "Bárbaro", "id": 13, "nome": "As melhores coisas da vida", "descricao": "No final da sessão, se tiver esmagado seus inimigos, vê-los fugir diante de sua presença e ouvir os lamentos de seus parentes, marque XP." },
        { "classe": "Bárbaro", "id": 14, "nome": "Grande viajante", "descricao": "No final da sessão, se tiver esmagado seus inimigos, vê-los fugir diante de sua presença e ouvir os lamentos de seus parentes, marque XP." },
        { "classe": "Bárbaro", "id": 15, "nome": "USURPADOR", "descricao": "Quando se provar superior a uma pessoa no poder, receba +1 adiante contra seus seguidores, lacaios e puxa-sacos." },
        { "classe": "Bárbaro", "id": 16, "nome": "KHAN DOS KHANS", "descricao": "Seus lacaios sempre aceitam a satisfação gratuita de um apetite seu como pagamento." },
        { "classe": "Bárbaro", "id": 17, "nome": "SANSÃO", "descricao": "Você pode aceitar uma debilidade para imediatamente se livrar de qualquer restrição física ou mental." },
        { "classe": "Bárbaro", "id": 18, "nome": "ESMAGAR!", "descricao": "Quando matar e pilhar, com <span class='badge'>12+</span> cause seu dano e escolha algum objeto físico que seu alvo possua (uma arma, sua posição, um membro): ele perde o objeto escolhido." },
        { "classe": "Bárbaro", "id": 19, "nome": "FOME INDESTRUTÍVEL", "descricao": "Quando for receber dano, você pode optar por receber -1 constante até saciar um de seus apetites no lugar do dano. Você não poderá escolher esta opção enquanto estiver com essa penalidade ativa." },
        { "classe": "Bárbaro", "id": 20, "nome": "PERCEPÇÃO DE PONTOS FRACOS", "descricao": "Quando discernir realidades, acrescente \u201co que aqui é fraco ou vulnerável?\u201d à lista de perguntas que você pode fazer." },
        { "classe": "Bárbaro", "id": 21, "nome": "SEMPRE EM FRENTE", "descricao": "Quando desafiar o perigo causado por algum movimento (como cair de uma ponte estreita ou passar correndo por um guarda armado), receba +1." }
      ],
